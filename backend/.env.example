# 应用配置
APP_NAME=英语教学资料格式适配工具
DEBUG=True

# 数据库(SQLite)
DATABASE_URL=sqlite+aiosqlite:///./data/english_tool.db

# 大模型配置(通义千问/DeepSeek)
LLM_API_KEY=you_api_key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 百度OCR配置
BAIDU_OCR_API_KEY=your-baidu-api-key
BAIDU_OCR_SECRET_KEY=your-baidu-secret-key

# OCR引擎选择: llm_vision (默认，使用大模型视觉能力) | baidu (百度OCR)
OCR_BACKEND=llm_vision

# 文件存储
MAX_UPLOAD_SIZE=52428800
TEMP_STORAGE_PATH=./tmp
TEMPLATE_STORAGE_PATH=./templates
TEMP_EXPIRE_HOURS=24

# 文档限制配置
DOCX_MAX_PAGES=30
PDF_MAX_PAGES=50
MAX_REVISIONS=500
LLM_MAX_TOKENS=20000

# Hybrid PDF解析配置(用于复杂/嵌套表格PDF的增强解析)
HYBRID_SERVER_ENABLED=True
HYBRID_SERVER_PORT=5002
HYBRID_SERVER_HOST=127.0.0.1
HYBRID_SERVER_TIMEOUT=300
HYBRID_SERVER_LOG_LEVEL=error
HYBRID_PARSE_TIMEOUT=600
HYBRID_FALLBACK_ON_FAILURE=True
